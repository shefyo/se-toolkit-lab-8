# Bot and LLM configuration
# Copy this file: cp .env.bot.example .env.bot.secret
# Then fill in your real values in .env.bot.secret
#
# NOTE: This is NOT the backend credentials file (.env.docker.secret).
# This file is for the Telegram bot and its LLM features.

# Telegram bot token (from @BotFather)
BOT_TOKEN=your-telegram-bot-token-here

# LMS backend connection (the bot calls these endpoints)
LMS_API_URL=http://localhost:42002
LMS_API_KEY=your-lms-api-key-here

# LLM provider configuration (for intent routing in Task 3)
# For Qwen Code API: the QWEN_API_KEY you set in ~/qwen-code-oai-proxy/.env
# For OpenRouter: your OpenRouter API key
LLM_API_KEY=your-llm-api-key-here

# API base URL (OpenAI-compatible endpoint)
# Qwen Code API on your VM:
LLM_API_BASE=http://localhost:42005/v1
# OpenRouter alternative:
# LLM_API_BASE=https://openrouter.ai/api/v1

# Model name
LLM_MODEL=qwen3-coder-plus
# OpenRouter alternative:
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
